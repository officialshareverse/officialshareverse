# Django
DJANGO_ENV=development
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=true
DJANGO_EXPOSE_DEV_OTP=true
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
DJANGO_CORS_ALLOWED_ORIGIN_REGEXES=
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
DJANGO_CORS_ALLOW_ALL_ORIGINS=false
DJANGO_SECURE_SSL_REDIRECT=true
DJANGO_SERVE_MEDIA=false
DJANGO_AUTH_REFRESH_COOKIE_NAME=sv_refresh_token
DJANGO_AUTH_REFRESH_COOKIE_SECURE=false
DJANGO_AUTH_REFRESH_COOKIE_SAMESITE=Lax
DJANGO_AUTH_REFRESH_COOKIE_PATH=/api/
DJANGO_AUTH_REFRESH_COOKIE_DOMAIN=

# Security
CREDENTIAL_ENCRYPTION_KEY=replace-with-a-stable-secret
DJANGO_GOOGLE_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
MSG91_AUTH_KEY=
MSG91_SIGNUP_FLOW_ID=
MSG91_PASSWORD_RESET_FLOW_ID=
MSG91_SENDER_ID=
MSG91_OTP_VARIABLE_NAME=OTP
MSG91_SMS_FLOW_API_URL=https://api.msg91.com/api/v5/flow/

# Razorpay
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_test_or_live_key_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret
RAZORPAY_COMPANY_NAME=ShareVerse
RAZORPAY_CURRENCY=INR

# RazorpayX payouts
RAZORPAYX_KEY_ID=
RAZORPAYX_KEY_SECRET=
RAZORPAYX_WEBHOOK_SECRET=
RAZORPAYX_SOURCE_ACCOUNT_NUMBER=

# Cache / Redis
DJANGO_REDIS_URL=
REDIS_URL=

# Preferred production database URL on Render or similar hosts
DATABASE_URL=

# Optional Postgres
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
